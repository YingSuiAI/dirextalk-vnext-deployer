class ContractError(RuntimeError):
    """An untrusted install artifact violated the frozen contract."""


def canonical(value: object) -> bytes:
    return (json.dumps(value, sort_keys=True, separators=(",", ":")) + "\n").encode()


def digest(data: bytes) -> str:
    return hashlib.sha256(data).hexdigest()


def reject_duplicate_keys(pairs: list[tuple[str, object]]) -> dict[str, object]:
    result: dict[str, object] = {}
    for key, value in pairs:
        if key in result:
            raise ContractError("JSON contains a duplicate key")
        result[key] = value
    return result


def decode_json(raw: bytes, label: str) -> object:
    try:
        return json.loads(raw, object_pairs_hook=reject_duplicate_keys)
    except (UnicodeDecodeError, json.JSONDecodeError) as error:
        raise ContractError(f"{label} is not valid JSON") from error


def safe_relative(value: str) -> bool:
    path = PurePosixPath(value)
    return bool(value) and not path.is_absolute() and ".." not in path.parts and str(path) == value


def ensure_root_directory(path: Path, mode: int) -> None:
    path.mkdir(parents=True, exist_ok=True)
    metadata = path.lstat()
    if (
        not stat.S_ISDIR(metadata.st_mode)
        or metadata.st_uid != STATE_OWNER_UID
        or metadata.st_gid != STATE_OWNER_GID
    ):
        raise ContractError(f"unsafe state directory: {path}")
    os.chmod(path, mode)


def secure_metadata(path: Path, expected_mode: int) -> os.stat_result:
    try:
        metadata = path.lstat()
    except FileNotFoundError as error:
        raise ContractError(f"required artifact is missing: {path}") from error
    if (
        not stat.S_ISREG(metadata.st_mode)
        or metadata.st_uid != STATE_OWNER_UID
        or metadata.st_gid != STATE_OWNER_GID
        or stat.S_IMODE(metadata.st_mode) != expected_mode
        or metadata.st_nlink != 1
    ):
        raise ContractError(f"artifact owner, type, link count, or mode is invalid: {path}")
    return metadata


def read_secure(path: Path, expected_mode: int, limit: int) -> bytes:
    before = secure_metadata(path, expected_mode)
    flags = os.O_RDONLY | os.O_CLOEXEC
    if hasattr(os, "O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    descriptor = os.open(path, flags)
    try:
        opened = os.fstat(descriptor)
        if (opened.st_dev, opened.st_ino) != (before.st_dev, before.st_ino) or opened.st_size > limit:
            raise ContractError(f"artifact changed or exceeds its size bound: {path}")
        chunks: list[bytes] = []
        size = 0
        while True:
            chunk = os.read(descriptor, min(1024 * 1024, limit + 1 - size))
            if not chunk:
                break
            size += len(chunk)
            if size > limit:
                raise ContractError(f"artifact exceeds its size bound: {path}")
            chunks.append(chunk)
        after = os.fstat(descriptor)
        if (after.st_dev, after.st_ino, after.st_size) != (opened.st_dev, opened.st_ino, opened.st_size):
            raise ContractError(f"artifact changed while it was read: {path}")
        return b"".join(chunks)
    finally:
        os.close(descriptor)


def validate_release_facts(value: dict[str, object], label: str) -> None:
    if value.get("schema_version") != 1 or value.get("target") != "linux-amd64":
        raise ContractError(f"{label} schema version or target is invalid")
    if not isinstance(value.get("domain"), str) or DOMAIN.fullmatch(value["domain"]) is None:
        raise ContractError(f"{label} domain is invalid")
    if not isinstance(value.get("version"), str) or SEMVER.fullmatch(value["version"]) is None:
        raise ContractError(f"{label} version is not SemVer")
    if not isinstance(value.get("source_commit"), str) or HEX40.fullmatch(value["source_commit"]) is None:
        raise ContractError(f"{label} source commit is invalid")
    for key in ("bundle_sha256", "manifest_sha256"):
        if not isinstance(value.get(key), str) or HEX64.fullmatch(value[key]) is None:
            raise ContractError(f"{label} {key} is invalid")
    for key in ("server_image", "migrator_image"):
        if not isinstance(value.get(key), str) or IMAGE.fullmatch(value[key]) is None:
            raise ContractError(f"{label} {key} is not an immutable production image")
    previous = value.get("previous_receipt_sha256")
    if previous is not None and (not isinstance(previous, str) or HEX64.fullmatch(previous) is None):
        raise ContractError(f"{label} previous receipt digest is invalid")


def validate_request(raw: bytes) -> dict[str, object]:
    request = decode_json(raw, "install request")
    if not isinstance(request, dict) or set(request) != REQUEST_KEYS:
        raise ContractError("install request keys are not exact")
    if request.get("schema") != REQUEST_SCHEMA:
        raise ContractError("install request schema is invalid")
    validate_release_facts(request, "install request")
    if raw != canonical(request):
        raise ContractError("install request is not canonical JSON")
    return request


def validate_manifest(raw: bytes) -> dict[str, object]:
    manifest = decode_json(raw, "bundle manifest")
    if not isinstance(manifest, dict) or set(manifest) != BUNDLE_KEYS:
        raise ContractError("bundle manifest keys are not exact")
    if manifest.get("schema") != BUNDLE_SCHEMA or manifest.get("schema_version") != 1:
        raise ContractError("bundle manifest schema is invalid")
    if manifest.get("target") != "linux-amd64":
        raise ContractError("bundle manifest target is invalid")
    if not isinstance(manifest.get("version"), str) or SEMVER.fullmatch(manifest["version"]) is None:
        raise ContractError("bundle manifest version is not SemVer")
    if not isinstance(manifest.get("source_commit"), str) or HEX40.fullmatch(manifest["source_commit"]) is None:
        raise ContractError("bundle manifest source commit is invalid")
    for key in ("server_image", "migrator_image"):
        if not isinstance(manifest.get(key), str) or IMAGE.fullmatch(manifest[key]) is None:
            raise ContractError(f"bundle manifest {key} is not immutable")
    if not isinstance(manifest.get("installer_sha256"), str) or HEX64.fullmatch(manifest["installer_sha256"]) is None:
        raise ContractError("bundle installer digest is invalid")
    files = manifest.get("files")
    if not isinstance(files, list) or not files:
        raise ContractError("bundle file allowlist is invalid")
    paths: list[str] = []
    for record in files:
        if not isinstance(record, dict) or set(record) != FILE_KEYS:
            raise ContractError("bundle file record keys are not exact")
        path = record.get("path")
        if not isinstance(path, str) or not safe_relative(path):
            raise ContractError("bundle file path is unsafe")
        if not isinstance(record.get("sha256"), str) or HEX64.fullmatch(record["sha256"]) is None:
            raise ContractError("bundle file digest is invalid")
        if record.get("mode") not in ("0444", "0555"):
            raise ContractError("bundle file mode is invalid")
        paths.append(path)
    if paths != sorted(paths) or len(paths) != len(set(paths)):
        raise ContractError("bundle files are not a sorted unique allowlist")
    installer_digest = next(
        (record["sha256"] for record in files if record["path"] == INSTALLER_PATH),
        None,
    )
    if manifest["installer_sha256"] != installer_digest:
        raise ContractError("bundle installer is not bound to the fixed installer path")
    if raw != canonical(manifest):
        raise ContractError("bundle manifest is not canonical JSON")
    return manifest


def required_directories(file_names: set[str]) -> set[str]:
    directories = {ARCHIVE_ROOT}
    for name in file_names:
        current = PurePosixPath(name).parent
        while str(current) != ".":
            directories.add(str(current))
            if str(current) == ARCHIVE_ROOT:
                break
            current = current.parent
    return directories


def validate_bundle(raw: bytes) -> tuple[dict[str, object], bytes, dict[str, bytes], dict[str, str]]:
    payloads: dict[str, bytes] = {}
    modes: dict[str, str] = {}
    directories: set[str] = set()
    seen: set[str] = set()
    total = 0
    try:
        archive = tarfile.open(fileobj=io.BytesIO(raw), mode="r:")
    except tarfile.TarError as error:
        raise ContractError("bundle is not an uncompressed tar archive") from error
    with archive:
        members = archive.getmembers()
        if len(members) > MAX_MEMBERS:
            raise ContractError("bundle contains too many members")
        for member in members:
            name = member.name.rstrip("/")
            if (
                name in seen
                or not safe_relative(name)
                or not (name == ARCHIVE_ROOT or name.startswith(ARCHIVE_ROOT + "/"))
            ):
                raise ContractError("bundle member path is unsafe or duplicated")
            seen.add(name)
            if member.pax_headers or member.issym() or member.islnk() or not (member.isdir() or member.isfile()):
                raise ContractError("bundle contains a link, special member, or extended metadata")
            if member.uid != 0 or member.gid != 0:
                raise ContractError("bundle member owner is not root")
            if member.isdir():
                if member.mode != 0o555:
                    raise ContractError("bundle directory mode is invalid")
                directories.add(name)
                continue
            if member.mode not in (0o444, 0o555) or member.size > MAX_BUNDLE_BYTES:
                raise ContractError("bundle file mode or size is invalid")
            total += member.size
            if total > MAX_BUNDLE_BYTES:
                raise ContractError("bundle payload exceeds its size bound")
            stream = archive.extractfile(member)
            if stream is None:
                raise ContractError("bundle file could not be read")
            payloads[name] = stream.read()
            modes[name] = f"{member.mode:04o}"
    manifest_name = f"{ARCHIVE_ROOT}/manifest.json"
    manifest_raw = payloads.pop(manifest_name, None)
    manifest_mode = modes.pop(manifest_name, None)
    if manifest_raw is None or manifest_mode != "0444" or len(manifest_raw) > MAX_MANIFEST_BYTES:
        raise ContractError("bundle manifest is missing or oversized")
    manifest = validate_manifest(manifest_raw)
    expected = {f"{ARCHIVE_ROOT}/{record['path']}": record for record in manifest["files"]}
    if set(payloads) != set(expected):
        raise ContractError("bundle file set differs from its manifest")
    if directories != required_directories(set(expected)):
        raise ContractError("bundle directory set differs from its manifest")
    for name, record in expected.items():
        if digest(payloads[name]) != record["sha256"] or modes[name] != record["mode"]:
            raise ContractError(f"bundle file contract mismatch: {name}")
    compatibility = payloads.get(f"{ARCHIVE_ROOT}/{COMPATIBILITY_PATH}")
    if compatibility != COMPATIBILITY:
        raise ContractError("bundle is missing the exact forward migration compatibility marker")
    relative_payloads = {name.removeprefix(ARCHIVE_ROOT + "/"): data for name, data in payloads.items()}
    relative_modes = {name.removeprefix(ARCHIVE_ROOT + "/"): mode for name, mode in modes.items()}
    return manifest, manifest_raw, relative_payloads, relative_modes


def request_matches_bundle(request: dict[str, object], manifest: dict[str, object], manifest_raw: bytes) -> None:
    for key in ("target", "version", "source_commit", "server_image", "migrator_image"):
        if request[key] != manifest[key]:
            raise ContractError(f"install request does not bind bundle field: {key}")
    if request["manifest_sha256"] != digest(manifest_raw):
        raise ContractError("install request manifest digest does not match the bundle")


def write_file(path: Path, data: bytes, mode: int) -> None:
    flags = os.O_WRONLY | os.O_CREAT | os.O_EXCL | os.O_CLOEXEC
    if hasattr(os, "O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW
    descriptor = os.open(path, flags, mode)
    try:
        os.fchown(descriptor, STATE_OWNER_UID, STATE_OWNER_GID)
        os.fchmod(descriptor, mode)
        view = memoryview(data)
        while view:
            written = os.write(descriptor, view)
            view = view[written:]
        os.fsync(descriptor)
    finally:
        os.close(descriptor)


def verify_release(
    release: Path,
    manifest: dict[str, object],
    manifest_raw: bytes,
    payloads: dict[str, bytes],
    modes: dict[str, str],
) -> None:
    expected_files = {"manifest.json": (manifest_raw, "0444")}
    expected_files.update({path: (data, modes[path]) for path, data in payloads.items()})
    expected_directories = {"."}
    for relative in expected_files:
        current = PurePosixPath(relative).parent
        while str(current) != ".":
            expected_directories.add(str(current))
            current = current.parent
    actual_files: set[str] = set()
    actual_directories: set[str] = set()
    for current, directory_names, file_names in os.walk(release, topdown=True, followlinks=False):
        current_path = Path(current)
        relative_directory = os.path.relpath(current_path, release)
        metadata = current_path.lstat()
        if (
            not stat.S_ISDIR(metadata.st_mode)
            or metadata.st_uid != STATE_OWNER_UID
            or metadata.st_gid != STATE_OWNER_GID
            or stat.S_IMODE(metadata.st_mode) != 0o555
        ):
            raise ContractError("installed release contains an unsafe directory")
        actual_directories.add(relative_directory)
        for name in directory_names:
            if (current_path / name).is_symlink():
                raise ContractError("installed release contains a symlink")
        for name in file_names:
            path = current_path / name
            relative = path.relative_to(release).as_posix()
            expected = expected_files.get(relative)
            if expected is None:
                raise ContractError("installed release contains an unexpected file")
            data, mode = expected
            if read_secure(path, int(mode, 8), MAX_BUNDLE_BYTES) != data:
                raise ContractError("installed release file digest differs from the bundle")
            actual_files.add(relative)
    if actual_files != set(expected_files) or actual_directories != expected_directories:
        raise ContractError("installed release file or directory set is incomplete")
    if manifest["installer_sha256"] != digest(payloads[INSTALLER_PATH]):
        raise ContractError("installed release fixed installer digest is invalid")


def materialize_release(
    bundle_sha256: str,
    manifest: dict[str, object],
    manifest_raw: bytes,
    payloads: dict[str, bytes],
    modes: dict[str, str],
) -> Path:
    target = RELEASE_ROOT / bundle_sha256
    stage = Path(tempfile.mkdtemp(prefix=".incoming-", dir=RELEASE_ROOT))
    os.chown(stage, STATE_OWNER_UID, STATE_OWNER_GID)
    os.chmod(stage, 0o700)
    try:
        entries = {"manifest.json": (manifest_raw, "0444")}
        entries.update({path: (data, modes[path]) for path, data in payloads.items()})
        directories = {stage}
        for relative, (data, mode) in sorted(entries.items()):
            path = stage / relative
            path.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
            current = path.parent
            while current != stage.parent:
                directories.add(current)
                if current == stage:
                    break
                current = current.parent
            write_file(path, data, int(mode, 8))
        for directory in sorted(directories, key=lambda item: len(item.parts), reverse=True):
            os.chown(directory, STATE_OWNER_UID, STATE_OWNER_GID)
            os.chmod(directory, 0o555)
        if target.exists() or target.is_symlink():
            verify_release(target, manifest, manifest_raw, payloads, modes)
            shutil.rmtree(stage)
        else:
            os.replace(stage, target)
            descriptor = os.open(RELEASE_ROOT, os.O_RDONLY | os.O_DIRECTORY | os.O_CLOEXEC)
            try:
                os.fsync(descriptor)
            finally:
                os.close(descriptor)
        verify_release(target, manifest, manifest_raw, payloads, modes)
        return target
    except Exception:
        if stage.exists():
            shutil.rmtree(stage)
        raise


def validate_receipt(raw: bytes) -> dict[str, object]:
    receipt = decode_json(raw, "installed release receipt")
    if not isinstance(receipt, dict) or set(receipt) != RECEIPT_KEYS:
        raise ContractError("installed release receipt keys are not exact")
    if receipt.get("schema") != RECEIPT_SCHEMA:
        raise ContractError("installed release receipt schema is invalid")
    validate_release_facts(receipt, "installed release receipt")
    if receipt.get("state") not in ("installed", "rolled_back"):
        raise ContractError("installed release receipt state is invalid")
    installed_at = receipt.get("installed_at_ms")
    if isinstance(installed_at, bool) or not isinstance(installed_at, int) or installed_at < 0:
        raise ContractError("installed release receipt timestamp is invalid")
    receipt_hash = receipt.get("receipt_sha256")
    if not isinstance(receipt_hash, str) or HEX64.fullmatch(receipt_hash) is None:
        raise ContractError("installed release receipt digest is invalid")
    body = dict(receipt)
    del body["receipt_sha256"]
    if digest(canonical(body)) != receipt_hash or raw != canonical(receipt):
        raise ContractError("installed release receipt is not canonical or self-authenticating")
    return receipt


def semver_key(value: str) -> tuple[tuple[int, int, int], tuple[tuple[int, object], ...]]:
    """Return a comparison key for the SemVer subset accepted by the bundle contract."""
    if SEMVER.fullmatch(value) is None:
        raise ContractError("release version is not SemVer")
    core, _, _metadata = value.partition("+")
    core, _, prerelease = core.partition("-")
    numbers = tuple(int(part) for part in core.split("."))
    if len(numbers) != 3:
        raise ContractError("release version is not SemVer")
    identifiers: list[tuple[int, object]] = []
    if prerelease:
        for identifier in prerelease.split("."):
            if identifier.isdigit():
                identifiers.append((0, int(identifier)))
            else:
                identifiers.append((1, identifier))
    # A release without a prerelease suffix sorts after all prereleases.
    return numbers, tuple(identifiers) if prerelease else ((2, ""),)


def strictly_forward(prior: str, candidate: str) -> bool:
    return semver_key(candidate) > semver_key(prior)


def admitted_cross_version(prior: str, candidate: str) -> bool:
    return (prior, candidate) == SUPPORTED_CROSS_VERSION and strictly_forward(prior, candidate)


def read_current_receipt() -> tuple[dict[str, object] | None, bytes | None]:
    if not CURRENT_RECEIPT.exists() and not CURRENT_RECEIPT.is_symlink():
        return None, None
    raw = read_secure(CURRENT_RECEIPT, 0o600, MAX_RECEIPT_BYTES)
    return validate_receipt(raw), raw


def find_candidate_receipt(
    request: dict[str, object],
) -> tuple[dict[str, object], bytes] | None:
    """Recover a receipt published before a crash interrupted current.json."""
    for path in sorted(RECEIPT_ROOT.glob("*.json")):
        if path == CURRENT_RECEIPT or path.is_symlink():
            continue
        try:
            raw = read_secure(path, 0o600, MAX_RECEIPT_BYTES)
            receipt = validate_receipt(raw)
        except (ContractError, OSError):
            continue
        if receipt["state"] == "installed" and request_matches_receipt(request, receipt):
            return receipt, raw
    return None


def make_receipt(facts: dict[str, object], state: str, previous: str | None) -> tuple[dict[str, object], bytes]:
    body = {
        "schema": RECEIPT_SCHEMA,
        "schema_version": 1,
        "target": facts["target"],
        "domain": facts["domain"],
        "version": facts["version"],
        "source_commit": facts["source_commit"],
        "bundle_sha256": facts["bundle_sha256"],
        "manifest_sha256": facts["manifest_sha256"],
        "server_image": facts["server_image"],
        "migrator_image": facts["migrator_image"],
        "previous_receipt_sha256": previous,
        "state": state,
        "installed_at_ms": time.time_ns() // 1_000_000,
    }
    receipt = dict(body)
    receipt["receipt_sha256"] = digest(canonical(body))
    raw = canonical(receipt)
    validate_receipt(raw)
    return receipt, raw


def atomic_replace(path: Path, raw: bytes, mode: int) -> None:
    descriptor, temporary_name = tempfile.mkstemp(prefix=f".{path.name}.", suffix=".tmp", dir=path.parent)
    temporary = Path(temporary_name)
    try:
        os.fchown(descriptor, STATE_OWNER_UID, STATE_OWNER_GID)
        os.fchmod(descriptor, mode)
        view = memoryview(raw)
        while view:
            written = os.write(descriptor, view)
            view = view[written:]
        os.fsync(descriptor)
        os.close(descriptor)
        descriptor = -1
        os.replace(temporary, path)
        descriptor = os.open(path.parent, os.O_RDONLY | os.O_DIRECTORY | os.O_CLOEXEC)
        try:
            os.fsync(descriptor)
        finally:
            os.close(descriptor)
            descriptor = -1
    finally:
        if descriptor >= 0:
            os.close(descriptor)
        if temporary.exists():
            temporary.unlink()


def atomic_write(path: Path, raw: bytes) -> None:
    atomic_replace(path, raw, 0o600)


def publish_receipt(facts: dict[str, object], state: str, previous: str | None) -> dict[str, object]:
    receipt, raw = make_receipt(facts, state, previous)
    history = RECEIPT_ROOT / f"{receipt['receipt_sha256']}.json"
    if history.exists() or history.is_symlink():
        if read_secure(history, 0o600, MAX_RECEIPT_BYTES) != raw:
            raise ContractError("receipt history digest collision")
    else:
        atomic_write(history, raw)
    atomic_write(CURRENT_RECEIPT, raw)
    return receipt


def load_retained_release(receipt: dict[str, object]) -> tuple[Path, dict[str, object]]:
    release = RELEASE_ROOT / str(receipt["bundle_sha256"])
    release_metadata = release.lstat()
    if (
        not stat.S_ISDIR(release_metadata.st_mode)
        or release_metadata.st_uid != STATE_OWNER_UID
        or release_metadata.st_gid != STATE_OWNER_GID
        or stat.S_IMODE(release_metadata.st_mode) != 0o555
    ):
        raise ContractError("retained release root is unsafe")
    manifest_raw = read_secure(release / "manifest.json", 0o444, MAX_MANIFEST_BYTES)
    manifest = validate_manifest(manifest_raw)
    if digest(manifest_raw) != receipt["manifest_sha256"]:
        raise ContractError("retained release manifest digest differs from its receipt")
    for key in ("target", "version", "source_commit", "server_image", "migrator_image"):
        if manifest[key] != receipt[key]:
            raise ContractError(f"retained release differs from receipt field: {key}")
    payloads: dict[str, bytes] = {}
    modes: dict[str, str] = {}
    for record in manifest["files"]:
        path = release / str(record["path"])
        payloads[str(record["path"])] = read_secure(path, int(str(record["mode"]), 8), MAX_BUNDLE_BYTES)
        modes[str(record["path"])] = str(record["mode"])
        if digest(payloads[str(record["path"])]) != record["sha256"]:
            raise ContractError("retained release file digest differs from its manifest")
    verify_release(release, manifest, manifest_raw, payloads, modes)
    return release, manifest


def compatible(release: Path) -> bool:
    try:
        return read_secure(release / COMPATIBILITY_PATH, 0o444, len(COMPATIBILITY)) == COMPATIBILITY
    except ContractError:
        return False


def request_matches_receipt(request: dict[str, object], receipt: dict[str, object]) -> bool:
    return all(request[key] == receipt[key] for key in (
        "target", "domain", "version", "source_commit", "bundle_sha256",
        "manifest_sha256", "server_image", "migrator_image",
    )) and request["previous_receipt_sha256"] == receipt["previous_receipt_sha256"]


def potentially_matches_request(
    request: dict[str, object],
    value: object,
) -> bool:
    keys = (
        "target", "domain", "version", "source_commit", "bundle_sha256",
        "manifest_sha256", "server_image", "migrator_image",
        "previous_receipt_sha256",
    )
    return isinstance(value, dict) and all(
        key in value and request[key] == value[key] for key in keys
    )


def fsync_directory(path: Path) -> None:
    descriptor = os.open(path, os.O_RDONLY | os.O_DIRECTORY | os.O_CLOEXEC)
    try:
        os.fsync(descriptor)
    finally:
        os.close(descriptor)


def disk_free_bytes(path: Path) -> int:
    return shutil.disk_usage(path).free


def remove_receipt_file(path: Path) -> None:
    secure_metadata(path, 0o600)
    path.unlink()


def maintain_receipt_storage(
    request: dict[str, object],
    current: dict[str, object] | None,
) -> tuple[set[str], set[str]]:
    explicit: set[str] = {
        value for value in (
            None if current is None else current["receipt_sha256"],
            None if current is None else current["previous_receipt_sha256"],
            request["previous_receipt_sha256"],
        )
        if isinstance(value, str)
    }
    records: dict[str, tuple[Path, dict[str, object], int]] = {}
    invalid_records: dict[str, tuple[Path, dict[str, object] | None]] = {}
    garbage: list[Path] = []
    for path in sorted(RECEIPT_ROOT.iterdir()):
        if path == CURRENT_RECEIPT:
            continue
        name = path.name
        if name.startswith(".") and name.endswith(".tmp") and len(name) <= 160:
            metadata = secure_metadata(path, 0o600)
            if metadata.st_size > MAX_RECEIPT_BYTES:
                raise ContractError("stale receipt temporary exceeds its size bound")
            garbage.append(path)
            continue
        match = re.fullmatch(r"([0-9a-f]{64})\.json", name)
        if match is None:
            raise ContractError(f"unexpected receipt storage entry: {path}")
        receipt_hash = match.group(1)
        metadata = secure_metadata(path, 0o600)
        if metadata.st_size > MAX_RECEIPT_BYTES:
            if receipt_hash in explicit:
                raise ContractError("recovery-referenced receipt exceeds its size bound")
            garbage.append(path)
            continue
        raw: bytes | None = None
        try:
            raw = read_secure(path, 0o600, MAX_RECEIPT_BYTES)
            receipt = validate_receipt(raw)
            if receipt["receipt_sha256"] != receipt_hash:
                raise ContractError("receipt history filename differs from its self-hash")
        except ContractError:
            candidate: dict[str, object] | None = None
            if raw is not None:
                try:
                    decoded = decode_json(raw, "invalid receipt history")
                    if isinstance(decoded, dict):
                        candidate = decoded
                except ContractError:
                    pass
            invalid_records[receipt_hash] = (path, candidate)
            garbage.append(path)
            continue
        records[receipt_hash] = (path, receipt, len(raw))

    # Resolve the complete authenticated reference graph before unlinking even
    # stale or malformed entries. Roots are current/request references; valid
    # installed descendants are crash-recoverable candidates. Every selected
    # receipt contributes its predecessor recursively.
    protected: set[str] = set()
    pending = list(explicit)
    while True:
        while pending:
            receipt_hash = pending.pop()
            if receipt_hash in protected:
                continue
            if receipt_hash in invalid_records:
                raise ContractError("an authoritative receipt history is corrupt")
            record = records.get(receipt_hash)
            if record is None:
                raise ContractError("an authoritative receipt history is missing")
            receipt = record[1]
            if (
                current is not None
                and receipt_hash == current["receipt_sha256"]
                and receipt != current
            ):
                raise ContractError("current receipt differs from its authoritative history")
            protected.add(receipt_hash)
            previous = receipt["previous_receipt_sha256"]
            if isinstance(previous, str):
                pending.append(previous)

        for receipt_hash, (_path, receipt, _size) in records.items():
            if (
                receipt_hash not in protected
                and receipt["state"] == "installed"
                and (
                    request_matches_receipt(request, receipt)
                    or receipt["previous_receipt_sha256"] in protected
                )
            ):
                pending.append(receipt_hash)
        for receipt_hash, (_path, candidate) in invalid_records.items():
            if receipt_hash in protected:
                raise ContractError("an authoritative receipt history is corrupt")
            previous = (
                None
                if candidate is None
                else candidate.get("previous_receipt_sha256")
            )
            if (
                potentially_matches_request(request, candidate)
                or (isinstance(previous, str) and previous in protected)
            ):
                raise ContractError("a recovery-referenced receipt history is corrupt")
        if not pending:
            break

    protected_release_digests = {str(request["bundle_sha256"])}
    required_release_digests: set[str] = set()
    if current is not None:
        current_bundle = str(current["bundle_sha256"])
        protected_release_digests.add(current_bundle)
        required_release_digests.add(current_bundle)
    for receipt_hash in protected:
        receipt = records[receipt_hash][1]
        release_digest = str(receipt["bundle_sha256"])
        protected_release_digests.add(release_digest)
        required_release_digests.add(release_digest)

    count_limit = MAX_RECEIPT_HISTORY - 1
    bytes_limit = MAX_RECEIPT_STORAGE_BYTES - RECEIPT_PUBLICATION_RESERVE
    protected_size = sum(records[value][2] for value in protected)
    current_size = 0 if current is None else len(canonical(current))
    if (
        count_limit < 1
        or bytes_limit < MAX_RECEIPT_BYTES
        or len(protected) > count_limit
        or protected_size + current_size > bytes_limit
    ):
        raise ContractError("recovery-referenced receipts exceed the bounded storage quota")
    for path in garbage:
        remove_receipt_file(path)
    if garbage:
        fsync_directory(RECEIPT_ROOT)
    unprotected = sorted(
        (
            (receipt["installed_at_ms"], receipt_hash, path, size)
            for receipt_hash, (path, receipt, size) in records.items()
            if receipt_hash not in protected
        ),
        reverse=True,
    )
    kept_extra = 0
    retained_size = protected_size + current_size
    removed = False
    for _installed_at, _receipt_hash, path, size in unprotected:
        if (
            kept_extra < RETAIN_UNREFERENCED_RECEIPTS
            and len(protected) + kept_extra + 1 <= count_limit
            and retained_size + size <= bytes_limit
        ):
            kept_extra += 1
            retained_size += size
        else:
            remove_receipt_file(path)
            removed = True
    if removed:
        fsync_directory(RECEIPT_ROOT)
    return protected_release_digests, required_release_digests


def release_tree_size(release: Path, root_mode: int = 0o555) -> int:
    root_metadata = release.lstat()
    release_root_metadata = RELEASE_ROOT.lstat()
    if (
        not stat.S_ISDIR(root_metadata.st_mode)
        or root_metadata.st_uid != STATE_OWNER_UID
        or root_metadata.st_gid != STATE_OWNER_GID
        or stat.S_IMODE(root_metadata.st_mode) != root_mode
        or root_metadata.st_dev != release_root_metadata.st_dev
        or os.path.ismount(release)
    ):
        raise ContractError(f"unsafe retained release directory: {release}")
    total = 0
    for current, directory_names, file_names in os.walk(release, topdown=True, followlinks=False):
        current_path = Path(current)
        metadata = current_path.lstat()
        allowed_directory_modes = {root_mode} if root_mode == 0o555 else {0o700, 0o555}
        if (
            not stat.S_ISDIR(metadata.st_mode)
            or metadata.st_uid != STATE_OWNER_UID
            or metadata.st_gid != STATE_OWNER_GID
            or stat.S_IMODE(metadata.st_mode) not in allowed_directory_modes
            or metadata.st_dev != root_metadata.st_dev
            or (current_path != release and os.path.ismount(current_path))
        ):
            raise ContractError("retained release contains an unsafe directory")
        for name in directory_names:
            path = current_path / name
            child = path.lstat()
            if (
                stat.S_ISLNK(child.st_mode)
                or child.st_dev != root_metadata.st_dev
                or os.path.ismount(path)
            ):
                raise ContractError("retained release crosses a symlink or mount boundary")
        for name in file_names:
            path = current_path / name
            child = path.lstat()
            if (
                not stat.S_ISREG(child.st_mode)
                or child.st_uid != STATE_OWNER_UID
                or child.st_gid != STATE_OWNER_GID
                or child.st_nlink != 1
                or stat.S_IMODE(child.st_mode) not in (0o444, 0o555)
                or child.st_dev != root_metadata.st_dev
            ):
                raise ContractError("retained release contains an unsafe file")
            total += child.st_size
    return total


def remove_release_tree(release: Path, root_mode: int = 0o555) -> None:
    release_tree_size(release, root_mode)
    directories = [Path(current) for current, _dirs, _files in os.walk(release, topdown=False)]
    for directory in directories:
        os.chmod(directory, 0o700)
    shutil.rmtree(release)
    fsync_directory(RELEASE_ROOT)


def maintain_release_storage(
    candidate_digest: str,
    protected_digests: set[str],
    required_digests: set[str],
    candidate_bytes: int,
) -> None:
    if candidate_bytes > MAX_BUNDLE_BYTES:
        raise ContractError("candidate release exceeds the 32 MiB bundle bound")
    records: list[tuple[int, str, Path, int]] = []
    for path in sorted(RELEASE_ROOT.iterdir()):
        name = path.name
        if name.startswith(".incoming-"):
            if len(name) > 96:
                raise ContractError("stale release staging name is invalid")
            release_tree_size(path, 0o700)
            remove_release_tree(path, 0o700)
            continue
        if HEX64.fullmatch(name) is None:
            raise ContractError(f"unexpected retained release entry: {path}")
        size = release_tree_size(path)
        if size > MAX_BUNDLE_BYTES:
            if name in protected_digests:
                raise ContractError("recovery-referenced release exceeds the 32 MiB bound")
            remove_release_tree(path)
            continue
        records.append((path.lstat().st_mtime_ns, name, path, size))
    present = {name for _mtime, name, _path, _size in records}
    missing = required_digests - present
    if missing:
        raise ContractError("a recovery-referenced retained release is missing")
    candidate_present = candidate_digest in present
    additional_bytes = 0 if candidate_present else candidate_bytes
    count_limit = MAX_RETAINED_RELEASES - (0 if candidate_present else 1)
    bytes_limit = MAX_RELEASE_STORAGE_BYTES - additional_bytes
    protected_records = [record for record in records if record[1] in protected_digests]
    protected_size = sum(record[3] for record in protected_records)
    if (
        count_limit < 1
        or bytes_limit < MAX_BUNDLE_BYTES
        or len(protected_records) > count_limit
        or protected_size > bytes_limit
    ):
        raise ContractError("recovery-referenced releases exceed the bounded storage quota")
    unprotected = sorted(
        (record for record in records if record[1] not in protected_digests),
        reverse=True,
    )
    kept_extra = 0
    retained_size = protected_size
    for _mtime, _name, path, size in unprotected:
        if (
            kept_extra < RETAIN_UNREFERENCED_RELEASES
            and len(protected_records) + kept_extra + 1 <= count_limit
            and retained_size + size <= bytes_limit
        ):
            kept_extra += 1
            retained_size += size
        else:
            remove_release_tree(path)
    if disk_free_bytes(RELEASE_ROOT) < MIN_RELEASE_FREE_BYTES + candidate_bytes:
        raise ContractError("insufficient free space for bounded release materialization")


def maintain_host_storage(
    request: dict[str, object],
    current: dict[str, object] | None,
    candidate_bytes: int,
) -> None:
    protected, required = maintain_receipt_storage(request, current)
    maintain_release_storage(str(request["bundle_sha256"]), protected, required, candidate_bytes)
    # Release and receipt roots commonly share the host filesystem. Check the
    # receipt floor only after both retention passes so releasable bundles can
    # satisfy admission; a separate receipt filesystem still fails closed.
    if disk_free_bytes(STATE_ROOT) < MIN_STATE_FREE_BYTES + RECEIPT_PUBLICATION_RESERVE:
        raise ContractError("insufficient free space for bounded receipt publication")


def install_code_only_rollback(release: Path, manifest: dict[str, object]) -> None:
    """Restore the retained release's code/config without touching schema or volumes."""
    files = {
        "docker/production/Caddyfile": (PRODUCTION_CONFIG_ROOT / "Caddyfile", 0o644),
        "docker/production/docker-compose.yml": (PRODUCTION_COMPOSE, 0o644),
        "tools/validate-production-images.py": (
            PRODUCTION_INSTALL_ROOT / "validate-production-images.py", 0o555
        ),
    }
    for relative, (destination, mode) in files.items():
        data = read_secure(release / relative, 0o555 if relative.endswith(".py") else 0o444, MAX_BUNDLE_BYTES)
        destination.parent.mkdir(parents=True, exist_ok=True)
        atomic_replace(destination, data, mode)
    # Keep all operator-owned configuration, secret, and TLS paths intact while
    # switching only the two executable image references and release identity.
    try:
        env_raw = read_secure(PRODUCTION_ENV, 0o644, MAX_BUNDLE_BYTES).decode()
        replacements = {
            "DTX_SERVER_IMAGE": str(manifest["server_image"]),
            "DTX_MIGRATOR_IMAGE": str(manifest["migrator_image"]),
            "DTX_RELEASE_VERSION": str(manifest["version"]),
        }
        lines = []
        replaced: set[str] = set()
        for line in env_raw.splitlines(keepends=True):
            key, separator, _value = line.partition("=")
            if separator and key in replacements:
                if key in replaced:
                    raise ContractError("production environment duplicates a rollback identity field")
                newline = "\n" if line.endswith("\n") else ""
                line = f"{key}={replacements[key]}{newline}"
                replaced.add(key)
            lines.append(line)
        if replaced != set(replacements):
            raise ContractError("production environment is missing a rollback identity field")
        env_data = "".join(lines).encode()
        atomic_replace(PRODUCTION_ENV, env_data, 0o644)
        atomic_replace(CURRENT_ENV, env_data, 0o600)
    except (UnicodeDecodeError, ContractError) as error:
        raise ContractError("production environment is unavailable for code-only rollback") from error
    # Reconcile only long-running containers.  --no-deps is the code-only
    # boundary: it cannot invoke bootstrap/migrate/grant/verify or any down
    # migration, and named volumes/secrets/TLS are left untouched.
    environment = {"PATH": "/usr/sbin:/usr/bin:/sbin:/bin", "LANG": "C.UTF-8"}
    subprocess.run(
        [
            "docker", "compose", "--project-name", "dirextalk-vnext-production",
            "--env-file", str(PRODUCTION_ENV), "-f", str(PRODUCTION_COMPOSE),
            "up", "-d", "--no-deps", "dtx-node", "realtime-gateway", "agent-control", "caddy",
        ],
        env=environment,
        stdin=subprocess.DEVNULL,
        check=True,
        timeout=600,
    )
    verifier = release / VERIFY_PATH
    read_secure(verifier, 0o555, MAX_BUNDLE_BYTES)
    subprocess.run(
        [str(verifier)],
        cwd=release,
        env=environment,
        stdin=subprocess.DEVNULL,
        check=True,
        timeout=600,
    )


def replace_runtime_identity(manifest: dict[str, object]) -> bytes:
    """Select an authenticated release without disturbing operator-owned env."""
    try:
        env_raw = read_secure(PRODUCTION_ENV, 0o644, MAX_BUNDLE_BYTES).decode()
    except (UnicodeDecodeError, ContractError) as error:
        raise ContractError("production environment is unavailable for activation") from error
    replacements = {
        "DTX_SERVER_IMAGE": str(manifest["server_image"]),
        "DTX_MIGRATOR_IMAGE": str(manifest["migrator_image"]),
        "DTX_RELEASE_VERSION": str(manifest["version"]),
    }
    lines: list[str] = []
    replaced: set[str] = set()
    for line in env_raw.splitlines(keepends=True):
        key, separator, _value = line.partition("=")
        if separator and key in replacements:
            if key in replaced:
                raise ContractError("production environment duplicates an activation identity field")
            line = f"{key}={replacements[key]}" + ("\n" if line.endswith("\n") else "")
            replaced.add(key)
        lines.append(line)
    if replaced != set(replacements):
        raise ContractError("production environment is missing an activation identity field")
    result = "".join(lines).encode()
    atomic_replace(PRODUCTION_ENV, result, 0o644)
    return result


